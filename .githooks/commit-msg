#!/usr/bin/env bash
set -u

# 本地 commit-msg hook：
# 1) 对 commit message 首行做轻量规范化（如全角冒号、大小写 type）
# 2) 按与远端 pre-receive 一致的规则校验，不通过则阻止提交

REGEX='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._/-]+\))?: .+'

print_error() {
  local msg="$1"

  echo "========================================" >&2
  echo "ERROR: commit message 不符合规范" >&2
  echo "========================================" >&2
  echo "当前标题: ${msg}" >&2
  echo "" >&2
  echo "要求格式:" >&2
  echo "  <type>: <subject>" >&2
  echo "  或" >&2
  echo "  <type>(<scope>): <subject>" >&2
  echo "" >&2
  echo "允许的 type:" >&2
  echo "  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert" >&2
  echo "" >&2
  echo "示例:" >&2
  echo "  feat: add login logic" >&2
  echo "  fix(auth): 修复 token 过期问题" >&2
  echo "========================================" >&2
}

normalize_subject() {
  local raw="$1"
  local s="$raw"

  # 去除首尾空白
  s="$(printf '%s' "$s" | awk '{sub(/^[[:space:]]+/, ""); sub(/[[:space:]]+$/, ""); print}')"
  # 将全角冒号替换为半角冒号
  s="${s//：/:}"
  # 统一冒号周围空格: "feat :x" / "feat:  x" -> "feat: x"
  s="$(printf '%s' "$s" | sed -E 's/^([A-Za-z]+(\([A-Za-z0-9._\/-]+\))?)[[:space:]]*:[[:space:]]*/\1: /')"

  # 统一 type 小写
  if [[ "$s" =~ ^([A-Za-z]+)(\([A-Za-z0-9._/-]+\))?:[[:space:]]*(.+)$ ]]; then
    local type scope subject
    type="$(printf '%s' "${BASH_REMATCH[1]}" | tr '[:upper:]' '[:lower:]')"
    scope="${BASH_REMATCH[2]}"
    subject="${BASH_REMATCH[3]}"
    s="${type}${scope}: ${subject}"
  fi

  printf '%s' "$s"
}

main() {
  local msg_file="${1:-}"
  if [ -z "$msg_file" ] || [ ! -f "$msg_file" ]; then
    echo "ERROR: commit-msg hook 未收到有效 message 文件参数" >&2
    exit 1
  fi

  local first_line normalized rest_file
  first_line="$(sed -n '1p' "$msg_file")"
  normalized="$(normalize_subject "$first_line")"

  # merge commit 直接放行（与远端规则一致）
  if printf '%s\n' "$normalized" | grep -Eq '^Merge '; then
    exit 0
  fi

  # 仅在首行被修正时写回 message 文件，便于开发者直接提交成功
  if [ "$normalized" != "$first_line" ]; then
    rest_file="$(mktemp)"
    tail -n +2 "$msg_file" > "$rest_file" 2>/dev/null || true
    {
      printf '%s\n' "$normalized"
      cat "$rest_file"
    } > "$msg_file"
    rm -f "$rest_file"
  fi

  if ! printf '%s\n' "$normalized" | grep -Eq "$REGEX"; then
    print_error "$normalized"
    exit 1
  fi

  exit 0
}

main "$@"
